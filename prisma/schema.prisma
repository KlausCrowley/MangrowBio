// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id            String   @id @default(uuid())
  name          String?
  email         String   @unique
  password_hash String
  created_at    DateTime @default(now())
}

model Contact {
  id               String   @id @default(uuid())
  name             String
  company          String?
  email            String
  service_required String?
  message          String
  status           String   @default("pending") // pending, contacted
  created_at       DateTime @default(now())

  @@index([email])
  @@index([status, created_at(sort: Desc)])
}

model CaseStudy {
  id         String   @id @default(uuid())
  title      String
  industry   String
  challenge  String
  solution   String
  results    String
  metrics    String
  created_at DateTime @default(now())

  @@index([industry, created_at(sort: Desc)])
  @@index([created_at(sort: Desc)])
}

model BlogPost {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  content        String
  category       String
  author         String
  featured_image String?
  created_at     DateTime @default(now())

  @@index([category, created_at(sort: Desc)])
  @@index([created_at(sort: Desc)])
}
